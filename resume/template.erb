<!DOCTYPE html>
<html lang='en'>
  <head>
    <title>resume | philip hallstrom | developer</title>
    <meta charset='utf-8'>
    <link href="/css/application.css" rel="stylesheet" media="all" />
    <link href="/css/print.css" rel="stylesheet" media="print" />
    <body class='resume'>
      <div class='container'>
        <h1>
          Resume
          <small class="muted">& Buzzword Compliance</small>
        </h1>
        <div class='row'>
          <div class='span9'>
            <section>
              <div class='row'>
                <div class='span2'>
                  <h3 class='packtop muted'>Philip Hallstrom</h3>
                </div>
                <div class='span7'>
                  <address>
                    <script type='text/javascript'>
                      //<![CDATA[
                      eval(unescape('%64%6f%63%75%6d%65%6e%74%2e%77%72%69%74%65%28%27%3c%61%20%68%72%65%66%3d%22%6d%61%69%6c%74%6f%3a%70%68%69%6c%69%70%40%70%6a%6b%68%2e%63%6f%6d%22%3e%70%68%69%6c%69%70%40%70%6a%6b%68%2e%63%6f%6d%3c%2f%61%3e%27%29%3b'))
                      //]]>
                    </script>
                    <br>
                    360.480.1209
                    <span class='hide print-show'>
                      <br />
                      https://pjkh.com/resume
                    </span>
                  </address>
                </div>
              </div>
            </section>
            <section>
              <div class='row'>
                <div class='span2'>
                  <h3>Skills</h3>
                </div>
                <div class='span7'>
                  <% skills.each do |s| -%>
                    <strong><%= s[:label] %></strong>
                    <p><%= s[:skills].sort.join(', ') %></p>
                  <% end -%>
                </div>
              </div>
            </section>
            <section>
              <div class='row'>
                <div class='span2'>
                  <h3 class='packtop muted'>Experience</h3>
                </div>
                <div class='span7'>
                  <% experience.each do |job| -%>
                    <strong><%= job[:company] %></strong>
                    <br>
                    <% job[:positions].each do |pos| -%>
                      <div class='pull-left muted'><%= pos[:title] %></div>
                      <div class='pull-right muted'><%= pos[:duration] %></div>
                      <br>
                    <% end -%>
                    <p><%= job[:description] %></p>
                    <% unless job[:details].to_s.empty? -%>
                      <ul>
                        <% job[:details].each do |detail| -%>
                          <li><%= detail %></li>
                        <% end -%>
                      </ul>
                    <% end -%>
                    <br>
                  <% end -%>
                </div>
              </div>
            </section>
            <section>
              <div class='row'>
                <div class='span2'>
                  <h3 class='packtop muted'>Education</h3>
                </div>
                <div class='span7'>
                  <% education.each do |school| -%>
                    <strong><%= school[:name] %></strong>
                    <br>
                    <div class='pull-left muted'><%= school[:location] %></div>
                    <div class='pull-right muted'><%= school[:duration] %></div>
                  <% end -%>
                </div>
              </div>
            </section>

          </div>
          <div class='span3'>
            <aside>
              <div class='well well-small'>
                <p>
                <strong>Attention Recruiters</strong>
                </p>
                <p>
                <small class='muted'>
                  I have worked remotely for <%= Date.today.year - 2006 %> years and am not looking to
                  relocate nor am I looking to work onsite in the Seattle area.
                </small>
                </p>
              </div>
              <div class='well well-small'>
                <p>
                <strong>Online Profiles</strong>
                </p>
                <p>
                <small class='muted'>
                  <a href='http://github.com/phallstrom' target='_blank'>GitHub</a>,
                  <a href='http://www.linkedin.com/in/phallstrom' target='_blank'>LinkedIn</a>,
                  <a href='http://stackoverflow.com/users/91830/philip-hallstrom' target='_blank'>Stack Overflow</a>.
                </small>
                </p>
              </div>
              <div class='well well-small'>
                <p>
                <strong>References</strong>
                </p>
                <p>
                <small class='muted'>
                  Available upon <script type="text/javascript">eval(unescape('%64%6f%63%75%6d%65%6e%74%2e%77%72%69%74%65%28%22%3c%61%20%68%72%65%66%3d%27%6d%61%69%6c%74%6f%3a%70%68%69%6c%69%70%40%70%6a%6b%68%2e%63%6f%6d%3f%73%75%62%6a%65%63%74%3d%52%65%71%75%65%73%74%20%66%6f%72%20%52%65%66%65%72%65%6e%63%65%73%27%3e%72%65%71%75%65%73%74%3c%2f%61%3e%22%29%3b'))</script>.
                </small>
                </p>
              </div>

            </aside>
          </div>
        </div>
      </div>
    </body>
  </head>
</html>
